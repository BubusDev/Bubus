

generator client {
  provider = "prisma-client-js"
} 

datasource db {
  provider  = "postgresql"
  url       = env("Bubus_DATABASE_URL")
  directUrl = env("Bubus_DATABASE_URL_UNPOOLED")
}

enum UserRole {
  USER
  ADMIN
}

enum HomepagePlacement {
  NONE
  SPOTLIGHT
  NEW_ARRIVALS
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum HomepageContentBlockKey {
  HERO
  INSTAGRAM
}

enum ProductOptionType {
  CATEGORY
  STONE_TYPE
  COLOR
  STYLE
  OCCASION
  AVAILABILITY
  VISUAL_TONE
}

enum AnnouncementVariant {
  DEFAULT
  SALE
  SPECIAL_EDITION
  NEW_COLLECTION
}

enum InventoryEventType {
  INITIAL_STOCK
  MANUAL_ADJUSTMENT
  ORDER_COMPLETED
}

enum OrderPaymentStatus {
  PENDING
  PROCESSING
  FINALIZING
  PAID
  FAILED
  CANCELED
  STOCK_UNAVAILABLE
}

enum GuestOrderAccessTokenKind {
  RECOVERY
  ACCESS
}

enum PromoCodeEligibilityRule {
  ALL_USERS
  REGISTERED_USERS_ONLY
}

enum PromoCodeApplicabilityScope {
  ALL_PRODUCTS
  CATEGORIES
  PRODUCTS
}

enum BlobCleanupStatus {
  PENDING
  DELETED
  KEPT
  FAILED
}

model User {
  id                     String     @id @default(cuid())
  name                   String
  email                  String     @unique
  passwordHash           String
  emailVerifiedAt        DateTime?
  role                   UserRole   @default(USER)
  phone                  String?
  birthDate              DateTime?
  profileImageUrl        String?
  defaultShippingAddress String?
  newsletterSubscribed   Boolean    @default(true)
  adminNotifyNewOrder    Boolean    @default(true)
  adminNotifyReturnRequest Boolean  @default(false)
  adminNotifyLowStock    Boolean    @default(true)
  adminNotifyWeeklySummary Boolean  @default(true)
  emailVerificationTokens EmailVerificationToken[]
  emailChangeTokens      EmailChangeToken[]
  passwordResetTokens    PasswordResetToken[]
  favourites             Favourite[]
  cart                   Cart?
  orders                 Order[]
  promoCodeRedemptions   PromoCodeRedemption[]
  promoCodeGrants        PromoCodeGrant[]
  weeklySummaryDispatches WeeklySummaryDispatch[]
  orderWorkflowHistoryEntries OrderWorkflowHistory[] @relation("OrderWorkflowHistoryChangedBy")
  returnRequestHistoryEntries ReturnRequestHistory[] @relation("ReturnRequestHistoryChangedBy")
  assignedOrders         Order[]    @relation("OrderAssignedTo")
  assignedReturnRequests ReturnRequest[] @relation("ReturnRequestAssignedTo")
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([newEmail, expiresAt])
}

model Product {
  id                String             @id @default(cuid())
  slug              String             @unique
  status            ProductStatus      @default(ACTIVE)
  name              String
  categoryId        String
  category          ProductOption      @relation("ProductCategory", fields: [categoryId], references: [id])
  price             Int
  compareAtPrice    Int?
  shortDescription  String
  description       String
  badge             String
  collectionLabel   String
  stockQuantity     Int                @default(0)
  reservedQuantity  Int                @default(0)
  soldOutAt         DateTime?
  stoneTypeId       String
  stoneType         ProductOption      @relation("ProductStoneType", fields: [stoneTypeId], references: [id])
  colorId           String
  color             ProductOption      @relation("ProductColor", fields: [colorId], references: [id])
  styleId           String
  style             ProductOption      @relation("ProductStyle", fields: [styleId], references: [id])
  occasionId        String
  occasion          ProductOption      @relation("ProductOccasion", fields: [occasionId], references: [id])
  availabilityId    String
  availability      ProductOption      @relation("ProductAvailability", fields: [availabilityId], references: [id])
  isNew             Boolean            @default(false)
  isGiftable        Boolean            @default(false)
  isOnSale          Boolean            @default(false)
  specialtyKey      String?
  toneId            String
  tone              ProductOption      @relation("ProductTone", fields: [toneId], references: [id])
  imageUrl          String?
  images            ProductImage[]
  slugHistory       ProductSlugHistory[]
  favourites        Favourite[]
  cartItems         CartItem[]
  promoCodes        PromoCodeProduct[]
  orderItems        OrderItem[]
  inventoryEvents   InventoryEvent[]
  specialEditionEntries SpecialEditionEntry[]
  specialties       ProductSpecialty[]
  listingPlacements ProductListingPlacement[]
  homepagePlacement HomepagePlacement  @default(NONE)
  archivedAt        DateTime?
  archiveReason     String?
  lowStockAlertSentAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([categoryId])
  @@index([stoneTypeId])
  @@index([colorId])
  @@index([styleId])
  @@index([occasionId])
  @@index([availabilityId])
  @@index([toneId])
  @@index([homepagePlacement])
  @@index([status])
  @@index([isNew])
  @@index([isGiftable])
  @@index([isOnSale])
  @@index([specialtyKey])
  @@index([stockQuantity, reservedQuantity])
}

model ProductSlugHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  slug      String   @unique
  createdAt DateTime @default(now())

  @@index([productId, createdAt])
}

model ProductOption {
  id                   String            @id @default(cuid())
  type                 ProductOptionType
  name                 String
  slug                 String
  isActive             Boolean           @default(true)
  isStorefrontVisible  Boolean           @default(true)
  showInMainNav        Boolean           @default(false)
  navSortOrder         Int               @default(0)
  navLabel             String?
  sortOrder            Int               @default(0)
  productsAsCategory   Product[]         @relation("ProductCategory")
  productsAsStoneType  Product[]         @relation("ProductStoneType")
  productsAsColor      Product[]         @relation("ProductColor")
  productsAsStyle      Product[]         @relation("ProductStyle")
  productsAsOccasion   Product[]         @relation("ProductOccasion")
  productsAsAvailability Product[]       @relation("ProductAvailability")
  productsAsTone       Product[]         @relation("ProductTone")
  promoCodesAsCategory PromoCodeCategory[]
  listingPlacements    ProductListingPlacement[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([type, slug])
  @@unique([type, name])
  @@index([type, isActive, sortOrder])
  @@index([type, isActive, isStorefrontVisible, showInMainNav, navSortOrder])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isCover   Boolean  @default(false)
  cardCropX Float    @default(0)
  cardCropY Float    @default(0)
  cardCropZoom Float @default(1)
  cardCropAspectRatio Float @default(0.75)
  cardCropAreaX Float @default(0)
  cardCropAreaY Float @default(0)
  cardCropAreaWidth Float @default(100)
  cardCropAreaHeight Float @default(100)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
  @@index([productId, isCover])
}

model ProductListingPlacement {
  id          String         @id @default(cuid())
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  listingKey  String
  listingType String
  categoryId  String?
  category    ProductOption? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  specialtyId String?
  specialty   Specialty?     @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  sortOrder   Int            @default(0)
  isPinned    Boolean        @default(false)
  isFeatured  Boolean        @default(false)
  isVisible   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([listingKey, productId])
  @@index([listingKey, sortOrder])
  @@index([listingType])
  @@index([productId])
  @@index([categoryId])
  @@index([specialtyId])
}

model BlobCleanupQueueItem {
  id             String            @id @default(cuid())
  url            String
  pathname       String?
  reason         String?
  status         BlobCleanupStatus @default(PENDING)
  scheduledAt    DateTime          @default(now())
  lastCheckedAt  DateTime?
  deletedAt      DateTime?
  failureMessage String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, scheduledAt])
  @@index([url, status])
}

model SpecialEditionCampaign {
  id              String                @id @default(cuid())
  slug            String                @unique @default("gifts")
  isActive        Boolean               @default(false)
  bannerImageUrl  String?
  bannerImageAlt  String?
  entries         SpecialEditionEntry[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model SpecialEditionEntry {
  id                String                 @id @default(cuid())
  campaignId        String
  campaign          SpecialEditionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId         String
  product           Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  promoImageUrl     String
  promoImageAlt     String?
  productImageUrl   String
  productImageAlt   String?
  sortOrder         Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([campaignId, sortOrder])
  @@index([productId])
}

model AnnouncementBar {
  id        String              @id @default(cuid())
  text      String
  href      String?
  isActive  Boolean             @default(false)
  variant   AnnouncementVariant @default(DEFAULT)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([isActive, updatedAt])
}

model HomepageContentBlock {
  id          String                  @id @default(cuid())
  key         HomepageContentBlockKey @unique
  title       String?
  eyebrow     String?
  body        String?
  imageUrl    String?
  imageAlt    String?
  buttonText  String?
  buttonHref  String?
  isVisible   Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([isVisible, key])
}

model HomepagePromoTile {
  id        String   @id @default(cuid())
  slotIndex Int
  title     String
  subtitle  String?
  href      String?
  imageUrl  String?
  imageAlt  String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slotIndex])
  @@index([isVisible, slotIndex])
}

model Specialty {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  shortDescription String?
  imageUrl         String?
  imageAlt         String?
  previewImageUrl  String?
  previewImageAlt  String?
  previewImageCropX Float              @default(0)
  previewImageCropY Float              @default(0)
  previewImageZoom  Float              @default(1)
  previewImageAspectRatio Float        @default(0.8)
  cardImageUrl     String?
  cardImageAlt     String?
  cardImageCropX   Float               @default(0)
  cardImageCropY   Float               @default(0)
  cardImageZoom    Float               @default(1)
  cardImageAspectRatio Float           @default(1.3333333333333333)
  cardTitle        String?
  cardDescription  String?
  ctaLabel         String?
  destinationHref  String?
  isVisible        Boolean            @default(true)
  sortOrder        Int                @default(0)
  products         ProductSpecialty[]
  listingPlacements ProductListingPlacement[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([isVisible, sortOrder])
}

model ProductSpecialty {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  specialtyId String
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([productId, specialtyId])
  @@index([specialtyId])
  @@index([productId])
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  guestToken String?   @unique
  promoCodeId String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([guestToken])
  @@index([promoCodeId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId, updatedAt])
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  guestEmail      String?
  guestAccessTokenHash String?    @unique
  orderNumber     String      @unique
  status          String
  paymentStatus   OrderPaymentStatus @default(PENDING)
  internalStatus  String      @default("received")
  trackingNumber  String?
  shippingMethod   String?
  foxpostPointCode String?
  internalNote     String?
  statusUpdatedAt DateTime?
  subtotal        Int
  discountAmount  Int         @default(0)
  promoCodeId     String?
  promoCodeText   String?
  promoDiscountPercent Int?
  total           Int
  currency        String      @default("HUF")
  shippingName    String
  shippingPhone   String
  shippingAddress String
  paymentMethod   String
  stripePaymentIntentId String? @unique
  paidAt          DateTime?
  confirmationEmailSendingAt DateTime?
  confirmationEmailSentAt DateTime?
  adminNewOrderNotificationSendingAt DateTime?
  adminNewOrderNotificationSentAt DateTime?
  assignedToId     String?
  statusUpdateEmailKey       String?
  statusUpdateEmailSendingKey String?
  statusUpdateEmailSendingAt DateTime?
  statusUpdateEmailSentAt    DateTime?
  items           OrderItem[]
  accessTokens    GuestOrderAccessToken[]
  returnRequests  ReturnRequest[]
  workflowHistory OrderWorkflowHistory[]
  promoCode       PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  promoCodeRedemption PromoCodeRedemption?
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo      User?       @relation("OrderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([promoCodeId])
  @@index([paymentStatus, createdAt])
  @@index([internalStatus, createdAt])
  @@index([assignedToId, createdAt])
}

model PromoCode {
  id                 String                 @id @default(cuid())
  code               String                 @unique
  discountPercent    Int
  eligibilityRule    PromoCodeEligibilityRule @default(ALL_USERS)
  applicabilityScope PromoCodeApplicabilityScope @default(ALL_PRODUCTS)
  validFrom          DateTime
  validUntil         DateTime?
  isActive           Boolean                @default(true)
  oneTimeUse         Boolean                @default(false)
  totalUsageLimit    Int?
  perCustomerUsageLimit Int?
  minimumOrderAmount Int?
  redeemedCount      Int                    @default(0)
  carts              Cart[]
  orders             Order[]
  redemptions        PromoCodeRedemption[]
  grants             PromoCodeGrant[]
  applicableCategories PromoCodeCategory[]
  applicableProducts   PromoCodeProduct[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([isActive, validFrom, validUntil])
  @@index([redeemedCount])
  @@index([applicabilityScope])
}

model PromoCodeCategory {
  id          String        @id @default(cuid())
  promoCodeId String
  categoryId  String
  promoCode   PromoCode     @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  category    ProductOption @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@unique([promoCodeId, categoryId])
  @@index([categoryId])
  @@index([promoCodeId])
}

model PromoCodeProduct {
  id          String    @id @default(cuid())
  promoCodeId String
  productId   String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([promoCodeId, productId])
  @@index([productId])
  @@index([promoCodeId])
}

model PromoCodeGrant {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  source      String
  cycle       String    @default("")
  createdAt   DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@unique([userId, source, cycle])
  @@index([userId, createdAt])
  @@index([source, cycle])
}

model PromoCodeRedemption {
  id            String    @id @default(cuid())
  promoCodeId   String
  orderId       String    @unique
  userId        String?
  customerEmail String?
  customerKey   String?
  discountAmount Int
  createdAt     DateTime  @default(now())
  promoCode     PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([promoCodeId, customerKey])
  @@index([promoCodeId, createdAt])
  @@index([userId, createdAt])
  @@index([customerEmail, createdAt])
}

model GuestOrderAccessToken {
  id        String                    @id @default(cuid())
  orderId    String
  order      Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tokenHash  String                    @unique
  kind       GuestOrderAccessTokenKind
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime                  @default(now())

  @@index([orderId, kind, expiresAt])
}

model GuestOrderRecoveryRequest {
  id        String   @id @default(cuid())
  ipHash    String
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  productSlug String
  imageUrl    String?
  unitPrice   Int
  quantity    Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model InventoryEvent {
  id          String             @id @default(cuid())
  productId   String
  orderId     String?
  type        InventoryEventType
  quantityDelta Int
  stockAfter  Int
  note        String?
  metadata    Json?
  createdAt   DateTime           @default(now())
  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([orderId])
  @@index([type, createdAt])
}

model ReturnRequest {
  id                     String   @id @default(cuid())
  orderId                String
  requesterEmail         String
  status                 String   @default("new")
  assignedToId           String?
  refundStatus           String   @default("not_refunded")
  refundedAmount         Int?
  refundedAt             DateTime?
  stripeRefundId         String?  @unique
  refundFailureReason    String?
  refundProcessingAt     DateTime?
  refundConfirmationEmailSendingAt DateTime?
  refundConfirmationEmailSentAt DateTime?
  refundFailureEmailSendingAt DateTime?
  refundFailureEmailSentAt DateTime?
  reason                 String?
  details                String
  adminNote              String?
  resolution             String?
  adminNotificationSentAt DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  order                  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo             User?    @relation("ReturnRequestAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  history                ReturnRequestHistory[]

  @@index([status, createdAt])
  @@index([orderId, createdAt])
  @@index([assignedToId, createdAt])
}

model OrderWorkflowHistory {
  id             String   @id @default(cuid())
  orderId         String
  previousStatus  String?
  newStatus       String
  changedAt       DateTime @default(now())
  changedById     String?
  source          String
  previousAssigneeLabel String?
  newAssigneeLabel String?
  assignmentChanged Boolean @default(false)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy       User?    @relation("OrderWorkflowHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([orderId, changedAt])
  @@index([changedById, changedAt])
}

model ReturnRequestHistory {
  id               String   @id @default(cuid())
  returnRequestId   String
  previousStatus    String?
  newStatus         String
  previousRefundStatus String?
  newRefundStatus   String?
  refundChanged     Boolean  @default(false)
  refundedAmount    Int?
  stripeRefundId    String?
  adminNoteChanged  Boolean  @default(false)
  resolutionChanged Boolean  @default(false)
  changedAt         DateTime @default(now())
  changedById       String?
  previousAssigneeLabel String?
  newAssigneeLabel String?
  assignmentChanged Boolean @default(false)
  returnRequest     ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  changedBy         User?    @relation("ReturnRequestHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([returnRequestId, changedAt])
  @@index([changedById, changedAt])
}

model WeeklySummaryDispatch {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  sentAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart, sentAt])
}

model HomeShowcaseTab {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  filterType  String
  filterValue String?
  maxItems    Int      @default(8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Stone {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  color       String
  colorHex    String
  shortDesc   String
  longDesc    String
  effects     String[]
  origin      String?
  chakra      String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}
