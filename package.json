{
  "name": "webchicks2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:seed:local-auth": "node --import tsx prisma/seed-local-auth.ts",
    "db:fix-category-option-names": "node prisma/fix-category-option-names.cjs",
    "vercel-build": "npm run db:migrate:deploy && npm run build"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.2",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@vercel/blob": "^2.3.3",
    "dotenv": "^16.6.1",
    "heic-convert": "^2.1.0",
    "lucide-react": "^1.0.1",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
