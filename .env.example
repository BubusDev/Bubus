Bubus_DATABASE_URL="postgresql://USER:PASSWORD@EP-EXAMPLE-POOLER.REGION.aws.neon.tech/postgres?sslmode=require&connect_timeout=15"
Bubus_DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@EP-EXAMPLE.REGION.aws.neon.tech/postgres?sslmode=require&connect_timeout=15"

# Use the pooled URL for the app runtime and the direct/unpooled URL for Prisma migrations.
# On Neon, the unpooled host usually does not include `-pooler` in the hostname.

# Public application URL.
APP_URL="https://your-domain.vercel.app"

# Local auth/browser testing:
# set AUTH_URL to your local dev origin so Auth.js cookies and redirects stay on localhost.
AUTH_URL="http://127.0.0.1:3000"
AUTH_TRUST_HOST="true"

# Stripe webshop payments.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: set this if Stripe should return to a different deployed origin than APP_URL.
# Example: STRIPE_RETURN_URL_BASE="https://shop.example.com"

# Auth.js / NextAuth production secret.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

