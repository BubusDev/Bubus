DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Public application URL.
APP_URL="https://your-domain.vercel.app"

# Auth.js / NextAuth production secret.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# Email verification delivery.
# Resend API key plus a verified sender address are required outside local development.
RESEND_API_KEY="re_xxx"
AUTH_EMAIL_FROM="Bubus <noreply@your-domain.com>"

# Required only if you use Vercel Blob uploads in production.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"
